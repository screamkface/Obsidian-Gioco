  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#918779"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#b56d32"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#347f99"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#9a6a16"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7e64ad"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#4a8260"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#34302b"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "support.variable.property",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#6b6358"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#918779"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#b85a4d"
      }
    },
    {
      "scope": [
        "markup.heading.1.markdown",
        "markup.heading.setext.1.markdown"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#4a8260"
      }
    },
    {
      "scope": "markup.heading.2.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#347f99"
      }
    },
    {
      "scope": "markup.heading.3.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#b85a4d"
      }
    },
    {
      "scope": "markup.heading.4.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#4a8260"
      }
    },
    {
      "scope": "markup.heading.5.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#7e64ad"
      }
    },
    {
      "scope": "markup.heading.6.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#b56d32"
      }
    },
    {
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#9a4f83"
      }
    },
    {
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#b56d32"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link.inline"
      ],
      "settings": {
        "foreground": "#3f7186"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#4a8260"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#4c5f50"
      }
    },
    {
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#9a6a16"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#b85a4d"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#347f99"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#9a6a16",
    "comment": {
      "foreground": "#918779",
      "italic": true
    },
    "decorator": "#9a4f83",
    "enum": "#9a6a16",
    "function": "#347f99",
    "interface": "#347f99",
    "keyword": "#7e64ad",
    "method": "#347f99",
    "namespace": "#7e64ad",
    "number": "#b56d32",
    "operator": "#918779",
    "property": "#6b6358",
    "regexp": "#9a6a16",
    "string": "#4a8260",
    "struct": "#9a6a16",
    "type": "#9a6a16",
    "variable": "#34302b"
  }
}
