  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#928374"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#af3a03"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#076678"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#b57614"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8f3f71"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#79740e"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#3c3836"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "support.variable.property",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#665c54"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#928374"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#9d0006"
      }
    },
    {
      "scope": [
        "markup.heading.1.markdown",
        "markup.heading.setext.1.markdown"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#79740e"
      }
    },
    {
      "scope": "markup.heading.2.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#076678"
      }
    },
    {
      "scope": "markup.heading.3.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#9d0006"
      }
    },
    {
      "scope": "markup.heading.4.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#79740e"
      }
    },
    {
      "scope": "markup.heading.5.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#8f3f71"
      }
    },
    {
      "scope": "markup.heading.6.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#af3a03"
      }
    },
    {
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#b16286"
      }
    },
    {
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#af3a03"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link.inline"
      ],
      "settings": {
        "foreground": "#076678"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#79740e"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#79740e"
      }
    },
    {
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#b57614"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#9d0006"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#076678"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#b57614",
    "comment": {
      "foreground": "#928374",
