  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#77766d"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#e3a06a"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7dbfd3"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#e2b55c"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#b99ad8"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#92c99d"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#d8d2c4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "support.variable.property",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#aaa396"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#77766d"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#e08a7a"
      }
    },
    {
      "scope": [
        "markup.heading.1.markdown",
        "markup.heading.setext.1.markdown"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#92c99d"
      }
    },
    {
      "scope": "markup.heading.2.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#7dbfd3"
      }
    },
    {
      "scope": "markup.heading.3.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#e08a7a"
      }
    },
    {
      "scope": "markup.heading.4.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#92c99d"
      }
    },
    {
      "scope": "markup.heading.5.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#b99ad8"
      }
    },
    {
      "scope": "markup.heading.6.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#e3a06a"
      }
    },
    {
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#dda0c7"
      }
    },
    {
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e3a06a"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link.inline"
      ],
      "settings": {
        "foreground": "#91c6d4"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#92c99d"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#b3c2b4"
      }
    },
    {
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#e2b55c"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#e08a7a"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#7dbfd3"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#e2b55c",
    "comment": {
      "foreground": "#77766d",
      "italic": true
    },
    "decorator": "#dda0c7",
    "enum": "#e2b55c",
    "function": "#7dbfd3",
    "interface": "#7dbfd3",
    "keyword": "#b99ad8",
    "method": "#7dbfd3",
    "namespace": "#b99ad8",
    "number": "#e3a06a",
    "operator": "#77766d",
    "property": "#aaa396",
    "regexp": "#e2b55c",
    "string": "#92c99d",
    "struct": "#e2b55c",
    "type": "#e2b55c",
    "variable": "#d8d2c4"
  }
