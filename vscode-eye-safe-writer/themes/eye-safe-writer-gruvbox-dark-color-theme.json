  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#928374"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#fe8019"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#83a598"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#fabd2f"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d3869b"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#b8bb26"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#ebdbb2"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "support.variable.property",
        "variable.other.property"
      ],
      "settings": {
        "foreground": "#bdae93"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#928374"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#fb4934"
      }
    },
    {
      "scope": [
        "markup.heading.1.markdown",
        "markup.heading.setext.1.markdown"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#b8bb26"
      }
    },
    {
      "scope": "markup.heading.2.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#83a598"
      }
    },
    {
      "scope": "markup.heading.3.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#fb4934"
      }
    },
    {
      "scope": "markup.heading.4.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#b8bb26"
      }
    },
    {
      "scope": "markup.heading.5.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#d3869b"
      }
    },
    {
      "scope": "markup.heading.6.markdown",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#fe8019"
      }
    },
    {
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#fe8019"
      }
    },
    {
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fe8019"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link.inline"
      ],
      "settings": {
        "foreground": "#83a598"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#8ec07c"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#b8bb26"
      }
    },
    {
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#fabd2f"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#fb4934"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#83a598"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#fabd2f",
    "comment": {
      "foreground": "#928374",
      "italic": true
    },
    "decorator": "#fe8019",
