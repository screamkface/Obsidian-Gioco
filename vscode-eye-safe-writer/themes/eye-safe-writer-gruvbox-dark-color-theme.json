    "keyword": "#d3869b",
    "method": "#83a598",
    "namespace": "#d3869b",
    "number": "#fe8019",
    "operator": "#928374",
    "property": "#bdae93",
    "regexp": "#fabd2f",
    "string": "#b8bb26",
    "struct": "#fabd2f",
    "type": "#fabd2f",
    "variable": "#ebdbb2"
